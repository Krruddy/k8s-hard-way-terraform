apiVersion: v1
kind: Config

clusters:
- name: kubernetes-the-hard-way
  cluster:
    certificate-authority-data: 
    server: https://127.0.0.1:6443

contexts:
- context:
    cluster: kubernetes-the-hard-way
    user: admin
  name: default
current-context: default
preferences: {}

users:
- name: admin
  user:
    client-certificate-data: 
    client-key-data: 
